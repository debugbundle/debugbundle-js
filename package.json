{
  "name": "debugbundle-js",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "description": "DebugBundle JavaScript SDK repository — sdk-node, sdk-browser",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/debugbundle/debugbundle-js.git"
  },
  "bugs": {
    "url": "https://github.com/debugbundle/debugbundle-js/issues"
  },
  "homepage": "https://github.com/debugbundle/debugbundle-js#readme",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "build": "pnpm --filter @debugbundle/sdk-node build && pnpm --filter @debugbundle/sdk-browser build",
    "prepare:release": "node scripts/prepare-release.mjs .tmp/npm-release"
  },
  "devDependencies": {
    "@debugbundle/shared-types": "0.1.7",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
